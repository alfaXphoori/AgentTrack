{
  "project_name": "AiKore Activity Tracker",
  "default_model": "gemini-1.5-flash",
  "timezone": "Asia/Bangkok",
  "token_estimation": {
    "enabled": true,
    "chars_per_token": 3.5
  },
  "display": {
    "show_workspace": true,
    "reverse_order": true,
    "max_logs_view": 50
  },
  "storage": {
    "log_file": "aikore_logs.json"
  }
}
